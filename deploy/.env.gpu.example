# ARIS GPU Deployment — Environment Variables
# Copy to .env and fill in your values
#
# Usage: docker compose -f docker-compose.gpu.yaml up -d

# ─── User ────────────────────────────────────────────────────────────────────
USERNAME=orangmood
USER_UID=1000
USER_GID=1000

# ─── ARIS Framework Branch ───────────────────────────────────────────────────
ARIS_BRANCH=orangmood-tripartite-night-20260512

# ─── API Keys ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
OPENAI_API_KEY=

# ─── Proxy (leave empty if direct) ──────────────────────────────────────────
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost

# ─── GPU ─────────────────────────────────────────────────────────────────────
# "all" = use all GPUs; "0,1" = specific GPUs
NVIDIA_VISIBLE_DEVICES=all
CUDA_VISIBLE_DEVICES=

# ─── Paths on host ──────────────────────────────────────────────────────────
# Project directory (exp0516 lives here)
PROJECT_PATH=/workspace/Orangmood/ARIS
# Datasets (optional)
DATASETS_PATH=/workspace/Orangmood/datasets
# Pretrained models (optional)
PRETRAINED_PATH=/workspace/Orangmood/pretrained
# SSH keys directory
SSH_PATH=/home/dell/.ssh
